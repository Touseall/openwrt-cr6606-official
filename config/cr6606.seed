# 目标平台：ramips / mt7621 / Xiaomi CR6606
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-cr6606=y

# 基础系统
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y

# 网络基础（旁路由常用）
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ca-certificates=y

# UPnP（旁路由端口自动转发）
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_luci-app-upnp=y

# SSR+ / Passwall（来自 kenzok8 feeds）
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-passwall=y

# SSR+ 依赖的一些常见内核/工具（具体依赖由 feeds 决定，这里给常见组合）
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-extra=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y

# TCP/UDP 透明代理常用
CONFIG_PACKAGE_redsocks2=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_microsocks=y

# FullCone（不同实现很多，这里先打开常见内核模块，具体实现由插件决定）
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_luci-app-fullconenat=y

# 常用工具
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_vim-full=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y

# LuCI 中文（如果你想要）
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# 去掉不需要的 PPPoE / IPv6（如果你只做旁路由，可选）
# CONFIG_PACKAGE_ppp is not set
# CONFIG_PACKAGE_ppp-mod-pppoe is not set
