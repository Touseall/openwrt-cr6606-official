###############################################
# Target: Xiaomi CR660X (CR6606 / CR6608 / CR6609)
###############################################
CONFIG_TARGET_ramips=y
CONFIG_TARGET_ramips_mt7621=y
CONFIG_TARGET_ramips_mt7621_DEVICE_xiaomi_mi-router-cr660x=y

###############################################
# Base System
###############################################
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-base=y

###############################################
# Language (Chinese)
###############################################
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

###############################################
# Wi-Fi Drivers (CR660X 官方驱动)
###############################################
CONFIG_PACKAGE_kmod-mt7603=y
CONFIG_PACKAGE_kmod-mt7615e=y
CONFIG_PACKAGE_kmod-mt7615-firmware=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_luci-app-wireless-regdb=y
CONFIG_PACKAGE_wpad-basic-mbedtls=y

###############################################
# PPPoE 拨号功能
###############################################
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_luci-proto-ppp=y

###############################################
# Argon 主题（并设为默认）
###############################################
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-i18n-argon-zh-cn=y
CONFIG_LUCI_DEFAULT_THEME="argon"

###############################################
# Networking (旁路由必备)
###############################################
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_kmod-nft-core=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_kmod-nft-socket=y

###############################################
# UPnP
###############################################
CONFIG_PACKAGE_miniupnpd=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y

###############################################
# FullCone NAT（OpenWrt master 已内置）
###############################################
CONFIG_PACKAGE_kmod-nft-fullcone=y
CONFIG_PACKAGE_luci-app-fullconenat=y
CONFIG_PACKAGE_luci-i18n-fullconenat-zh-cn=y

###############################################
# Passwall（含 Xray-core）
###############################################
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_haproxy=y
CONFIG_PACKAGE_ipt2socks=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_redsocks2=y

###############################################
# Tools
###############################################
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_nping=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y

###############################################
# IPv6（旁路由可选关闭）
###############################################
CONFIG_IPV6=n
CONFIG_PACKAGE_dnsmasq_full_dhcpv6=n
CONFIG_PACKAGE_odhcp6c=n
CONFIG_PACKAGE_odhcpd-ipv6only=n

###############################################
# End
###############################################
